{
  "description": "Shared GeoJSON geometry vectors. Feature *properties* differ per platform by design (simplestyle vs flat keys); the *geometry* must be identical: [lon, lat] ordering and implicit polygon ring closure.",
  "point": {
    "input": { "lat": 37.7749, "lon": -122.4194 },
    "geometry": { "type": "Point", "coordinates": [-122.4194, 37.7749] }
  },
  "line": {
    "input": [ { "lat": 1, "lon": 2 }, { "lat": 3, "lon": 4 } ],
    "geometry": { "type": "LineString", "coordinates": [[2, 1], [4, 3]] }
  },
  "polygon": {
    "input": [ { "lat": 0, "lon": 0 }, { "lat": 0, "lon": 1 }, { "lat": 1, "lon": 1 } ],
    "geometry": { "type": "Polygon", "coordinates": [[[0, 0], [1, 0], [1, 1], [0, 0]]] }
  }
}
